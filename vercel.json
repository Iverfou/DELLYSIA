{
  "version": 2,
  "routes": [
    { "src": "/api/chat",       "dest": "/api/chat.js" },
    { "src": "/api/rdv",        "dest": "/api/rdv.js"  },
    { "src": "/api/profil",     "dest": "/api/profil.js" },
    { "src": "/api/newsletter", "dest": "/api/newsletter.js" },
    { "src": "/agenda.html",    "dest": "/agenda.html" },
    { "src": "/agenda",         "dest": "/agenda.html" },
    { "src": "/biens.html",     "dest": "/biens.html"  },
    { "src": "/biens",          "dest": "/biens.html"  },
    { "src": "/profil.html",    "dest": "/profil.html" },
    { "src": "/profil",         "dest": "/profil.html" },
    { "src": "/",               "dest": "/index.html"  },
    { "src": "/(.*)",           "dest": "/index.html"  }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Cache-Control",          "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
